{
  "manifest_version": 3,
  "name": "LinkedIn Copilot",
  "description": "Analyze jobs, tailor a resume from your experience, and assist with Easy Apply workflows.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "contextMenus"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Easy Apply Copilot",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*", "https://*.indeed.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
